+
+    private static boolean readServerSettingFlag(String key, boolean defaultValue) throws Exception {
+        File f = serverSettingsFile();
+        if (f == null || !f.exists() || f.length() == 0) return defaultValue;
+        String json = readTextFile(f);
+        if (json == null) return defaultValue;
+        String compact = json.replaceAll("\\s+", "").toLowerCase();
+        String lookup = "\"" + key.toLowerCase() + "\":";
+        int idx = compact.indexOf(lookup);
+        if (idx < 0) return defaultValue;
+        String after = compact.substring(idx + lookup.length());
+        if (after.startsWith("true")) return true;
+        if (after.startsWith("false")) return false;
+        return defaultValue;
+    }
